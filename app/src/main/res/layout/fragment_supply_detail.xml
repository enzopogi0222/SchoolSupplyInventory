<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Photo"
            style="?android:listSeparatorTextViewStyle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <ImageView
                android:id="@+id/supply_photo"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:background="@android:color/darker_gray"
                android:contentDescription="Supply photo placeholder" />

            <Button
                android:id="@+id/supply_camera"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Take Photo" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Item Name"
            style="?android:listSeparatorTextViewStyle" />

        <EditText
            android:id="@+id/supply_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter supply name" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Brand"
            style="?android:listSeparatorTextViewStyle" />

        <EditText
            android:id="@+id/supply_brand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter brand" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category"
            style="?android:listSeparatorTextViewStyle" />

        <Spinner
            android:id="@+id/supply_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location / Room"
            style="?android:listSeparatorTextViewStyle" />

        <Button
            android:id="@+id/supply_room_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Room" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Details"
            style="?android:listSeparatorTextViewStyle" />

        <Button
            android:id="@+id/supply_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Borrower"
            style="?android:listSeparatorTextViewStyle" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/supply_borrower_display"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="None"
                android:textSize="16sp"
                android:padding="8dp"/>

            <Button
                android:id="@+id/supply_scan_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scan ID" />
        </LinearLayout>

        <Button
            android:id="@+id/supply_delete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Delete Item"
            android:backgroundTint="@android:color/holo_red_dark"
            android:textColor="@android:color/white" />

        <!-- Action Buttons Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <!-- Return button only -->
            <Button
                android:id="@+id/supply_return"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/return_item"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/last_updated_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray"
            android:padding="4dp"
            android:text="Last updated: Just now" />

    </LinearLayout>
</ScrollView>
